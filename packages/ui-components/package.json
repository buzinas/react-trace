{
  "name": "@react-trace/ui-components",
  "version": "0.0.0",
  "description": "Shared UI primitives (buttons, tooltips, popovers, icons) for react-trace plugins",
  "license": "MIT",
  "author": "Vitor Buzinaro",
  "repository": {
    "type": "git",
    "url": "https://github.com/buzinas/react-trace",
    "directory": "packages/ui-components"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react-trace"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "production": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.prod.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.prod.cjs"
        }
      },
      "default": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "oxlint": "latest",
    "react": "^19",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
