{
  "name": "@react-trace/plugin-open-editor",
  "version": "0.0.5",
  "description": "react-trace plugin: open inspected component source in your code editor",
  "keywords": [
    "react-trace",
    "react-trace-plugin"
  ],
  "license": "MIT",
  "author": "Vitor Buzinaro",
  "repository": {
    "type": "git",
    "url": "https://github.com/buzinas/react-trace",
    "directory": "packages/plugin-open-editor"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "production": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.prod.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.prod.cjs"
        }
      },
      "default": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/react": "^19",
    "oxlint": "latest",
    "react": "^19",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@react-trace/core": "workspace:^",
    "@react-trace/ui-components": "workspace:^",
    "jotai": "^2.18.0",
    "react": ">=18"
  }
}
