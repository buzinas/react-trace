{
  "name": "@react-xray/plugin-preview",
  "version": "0.0.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "production": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.prod.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.prod.cjs"
        }
      },
      "default": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@shikijs/monaco": "^4.0.1",
    "shiki": "^4.0.1"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@react-xray/core": "workspace:*",
    "@types/node": "^24.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19.2.3",
    "monaco-types": "^0.1.2",
    "oxlint": "latest",
    "react": "^19",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@react-xray/core": "workspace:*",
    "react": ">=18"
  }
}
