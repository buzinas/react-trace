{
  "name": "@react-trace/plugin-comments",
  "version": "0.0.3",
  "description": "react-trace plugin: inline code comments with OpenCode AI integration",
  "keywords": [
    "react-trace",
    "react-trace-agents",
    "react-trace-ai",
    "react-trace-comments",
    "react-trace-plugin"
  ],
  "license": "MIT",
  "author": "Vitor Buzinaro",
  "repository": {
    "type": "git",
    "url": "https://github.com/buzinas/react-trace",
    "directory": "packages/plugin-comments"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "production": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.prod.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.prod.cjs"
        }
      },
      "default": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.16",
    "jotai": "^2.18.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "oxlint": "latest",
    "react": "^19",
    "react-dom": "^19",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@react-trace/core": "workspace:^",
    "@react-trace/ui-components": "workspace:^",
    "react": ">=18",
    "react-dom": ">=18"
  }
}
