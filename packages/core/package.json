{
  "name": "@react-xray/core",
  "version": "0.0.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "production": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.prod.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.prod.cjs"
        }
      },
      "default": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "@react-xray/ui-components": "workspace:*",
    "jotai": "^2.18.0",
    "jotai-family": "^1.0.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/wicg-file-system-access": "^2023.10.7",
    "oxlint": "latest",
    "react": "^19",
    "react-dom": "^19",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5",
    "vitest": "latest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
