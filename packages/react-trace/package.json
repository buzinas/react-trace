{
  "name": "@react-trace/kit",
  "version": "0.0.1",
  "description": "Batteries-included React visual inspector — all official plugins pre-wired.",
  "keywords": [
    "react-find",
    "react-find-source",
    "react-grab",
    "react-inspect",
    "react-inspector",
    "react-trace"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "production": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.prod.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.prod.cjs"
        }
      },
      "default": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@react-trace/core": "workspace:*",
    "@react-trace/plugin-comments": "workspace:*",
    "@react-trace/plugin-copy-to-clipboard": "workspace:*",
    "@react-trace/plugin-open-editor": "workspace:*",
    "@react-trace/plugin-preview": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "oxlint": "latest",
    "react": "^19",
    "react-dom": "^19",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
