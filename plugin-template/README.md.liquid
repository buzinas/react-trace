## Usage

```tsx
{% if workspace %}import { Trace } from '@react-trace/core'
{% else %}import { Trace } from '@react-trace/kit'
{% endif %}import { {{ pluginName | pascalCase }}Plugin } from '{{ packageName }}'

import App from './App'

export function AppWithTrace() {
  return (
    <>
      <App />
      <Trace
        root={import.meta.env.VITE_ROOT}
        plugins={[{{ pluginName | pascalCase }}Plugin()]}
      />
    </>
  )
}
```
